# Local runtime data. Keep real .env files out of git.
# This file is safe to commit because it contains placeholders and local defaults only.
SCIENTIFIC_SPACES_DATA_DIR=.local_data/scientific_spaces

# Structured persistence. JSON remains the default compatibility backend.
SCIENTIFIC_SPACES_DB_FILE=.local_data/scientific_spaces/scientific_spaces.db
SCIENTIFIC_SPACES_LEARNING_BACKEND=json

# Optional storage file overrides.
# SCIENTIFIC_SPACES_ARTICLES_FILE=.local_data/scientific_spaces/articles.json
# SCIENTIFIC_SPACES_LEARNING_FILE=.local_data/scientific_spaces/learning.json
# SCIENTIFIC_SPACES_ZOTERO_FILE=.local_data/scientific_spaces/zotero_links.json
# SCIENTIFIC_SPACES_GRAPH_FILE=.local_data/scientific_spaces/knowledge_graph.json
# SCIENTIFIC_SPACES_TUTOR_FILE=.local_data/scientific_spaces/tutor_sessions.json

# Source sync options.
SCIENTIFIC_SPACES_SOURCE_STRATEGY=auto
SCIENTIFIC_SPACES_FEED_URL=https://spaces.ac.cn/feed
SCIENTIFIC_SPACES_MAX_PAGES=1
SCIENTIFIC_SPACES_MAX_ARTICLES=5

# Provider defaults are fake/local-testable. No API key is required for tests.
SCIENTIFIC_SPACES_ZOTERO_PROVIDER=fake
SCIENTIFIC_SPACES_ZOTERO_BASE_URL=http://127.0.0.1:23119
SCIENTIFIC_SPACES_TUTOR_LLM_PROVIDER=fake

# Optional OpenAI-compatible providers.
# Leave OPENAI_API_KEY blank here. Put real keys only in an untracked local .env
# file or in the deployment environment.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Frontend API target.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
